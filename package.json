{
  "name": "cue",
  "version": "0.1.0",
  "description": "An app runtime for agents. Actions, triggers, BYO UI.",
  "license": "MIT",
  "author": "Jason Normore",
  "type": "module",
  "bin": {
    "cue": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jnormore/cue.git"
  },
  "homepage": "https://github.com/jnormore/cue#readme",
  "bugs": {
    "url": "https://github.com/jnormore/cue/issues"
  },
  "keywords": [
    "mcp",
    "agent",
    "cron",
    "webhook",
    "sandbox",
    "unikernel",
    "unitask"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "vitest run --config vitest.smoke.config.ts",
    "cli": "vitest run --config vitest.cli.config.ts",
    "integration": "vitest run --config vitest.integration.config.ts",
    "verify": "npm run typecheck && npm run build && npm test && npm run smoke && npm run cli"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/sensible": "^6.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.1.0",
    "fastify": "^5.0.0",
    "node-cron": "^4.2.0",
    "smol-toml": "^1.3.0",
    "ulidx": "^2.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
